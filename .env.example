# SMA Ennox Configuration
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your credentials below
# 3. The .env file is git-ignored and will NOT be committed
#
# Get your credentials from: https://ennexos.sunnyportal.com
# Find your component_id in the URL after logging in

SMA_USERNAME=your-email@example.com
SMA_PASSWORD=your-password
SMA_COMPONENT_ID=your-component-id
